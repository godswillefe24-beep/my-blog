# Email Configuration
# For Gmail: use an App Password (not your regular password)
# See: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# SendGrid Alternative (optional - used if SENDGRID_API_KEY is set)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=no-reply@essence-blog.com

# Mailchimp Integration (optional - used if both are set)
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_LIST_ID=your-mailchimp-list-id

# Admin Security (IMPORTANT: Change these in production!)
ADMIN_PASSWORD=change-this-to-a-strong-password
JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars

# Server Configuration
PORT=3001
NODE_ENV=development
